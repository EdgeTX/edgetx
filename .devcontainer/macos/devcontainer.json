// EdgeTX devcontainer with host audio and display (X11) passthrough for
// macOS. Requires a PulseAudio server and XQuartz running on the Mac
// (one-time setup, see ../README.md). Keep in sync with ../devcontainer.json.
{
	"name": "edgetx-dev (macOS)",
	"image": "ghcr.io/edgetx/edgetx-dev:latest",
	"runArgs": [
		"--ipc=host",
		"-e", "DISPLAY=host.docker.internal:0"
	],
	"containerEnv": {
		"PULSE_SERVER": "tcp:host.docker.internal:4713"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools"
			]
		}
	},
	// Post-create command to set up the environment
	"postCreateCommand": "git submodule update --init --recursive && mkdir -p build && echo 'EdgeTX development environment ready!'"
}
