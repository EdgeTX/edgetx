  "buildPresets": [
    {
      "name": "firmware",
      "hidden": true,
      "configurePreset": "tx16s",
      "targets": ["firmware"]
    },
    {
      "name": "companion",
      "displayName": "Companion",
      "configurePreset": "companion",
      "targets": ["companion"]
    },
    {
      "name": "simu",
      "displayName": "SDL Simulator",
      "configurePreset": "simu",
      "targets": ["simu"]
    },
    {
      "name": "tests-radio",
      "displayName": "Radio Tests",
      "configurePreset": "simu",
      "targets": ["tests-radio"]
