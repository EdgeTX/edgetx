{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "cacheVariables": {
        "FETCHCONTENT_BASE_DIR": "${sourceDir}/.cache/fetchcontent"
      },
      "warnings": {
        "dev": false
      }
    },

    {
      "name": "firmware",
      "hidden": true,
      "inherits": "default",
      "binaryDir": "build/${presetName}",
      "toolchainFile": "cmake/toolchain/arm-none-eabi.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": false
      }
    },

    {
      "name": "native",
      "hidden": true,
      "inherits": "default",
      "binaryDir": "build/${presetName}",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true
      }
    },

    {
      "name": "companion",
      "displayName": "Companion",
      "inherits": "native",
      "binaryDir": "build/companion"
    },
    {
      "name": "simu",
      "displayName": "SDL Simulator",
      "inherits": "native",
      "binaryDir": "build/simu"
    },

    {
      "name": "tx16s",
      "displayName": "RadioMaster TX16S",
      "inherits": "firmware",
      "cacheVariables": { "PCB": "X10", "PCBREV": "TX16S" }
    },
    {
      "name": "tx16smk3",
      "displayName": "RadioMaster TX16S MK3",
      "inherits": "firmware",
      "cacheVariables": { "PCB": "TX16SMK3" }
    },
    {
      "name": "boxer",
      "displayName": "RadioMaster Boxer",
      "inherits": "firmware",
      "cacheVariables": { "PCB": "X7", "PCBREV": "BOXER" }
    },
    {
